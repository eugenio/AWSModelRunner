# NadirClaw configuration — Bedrock Mantle only (eu-west-2)
# All models routed through AWS Bedrock Mantle (OpenAI-compatible endpoint)

# Default Bedrock Mantle endpoint (eu-west-2 London)
NADIRCLAW_API_BASE=https://bedrock-mantle.eu-west-2.api.aws/v1
# OPENAI_API_KEY loaded from ~/.nadirclaw/mantle.env via docker-compose env_file

# Three-tier routing (all Bedrock)
#   Budget:  Qwen3 Coder 30B  -  32K ctx, $0.15/$0.60/M
#   Mid:     Qwen3 Coder Next - 128K ctx, coding-optimized
#   Premium: Qwen3 Coder 480B - 262K ctx, $0.45/$1.80/M (max context on Bedrock)
NADIRCLAW_SIMPLE_MODEL=openai/qwen.qwen3-coder-30b-a3b-v1:0
NADIRCLAW_MID_MODEL=openai/qwen.qwen3-coder-next
NADIRCLAW_COMPLEX_MODEL=openai/qwen.qwen3-coder-480b-a35b-v1:0

# Tier thresholds (score 0-1: <= simple_max -> budget, >= complex_min -> premium)
NADIRCLAW_TIER_THRESHOLDS=0.35,0.65

# Fallback chains (all Bedrock, ordered by capability then cost)
NADIRCLAW_FALLBACK_CHAIN=openai/qwen.qwen3-coder-480b-a35b-v1:0,openai/qwen.qwen3-coder-next,openai/moonshotai.kimi-k2.5,openai/qwen.qwen3-coder-30b-a3b-v1:0
NADIRCLAW_SIMPLE_FALLBACK=openai/qwen.qwen3-coder-next,openai/minimax.minimax-m2.1,openai/zai.glm-4.7
NADIRCLAW_MID_FALLBACK=openai/qwen.qwen3-coder-480b-a35b-v1:0,openai/moonshotai.kimi-k2.5,openai/zai.glm-4.7
NADIRCLAW_COMPLEX_FALLBACK=openai/qwen.qwen3-coder-next,openai/moonshotai.kimi-k2.5,openai/zai.glm-4.7

# Budget controls (USD)
NADIRCLAW_DAILY_BUDGET=5.00
NADIRCLAW_MONTHLY_BUDGET=80.00
NADIRCLAW_BUDGET_WARN_THRESHOLD=0.8
NADIRCLAW_BUDGET_STDOUT_ALERTS=true
NADIRCLAW_BUDGET_ENFORCE=true

# Context optimization DISABLED — the optimizer strips tool_calls and
# tool_call_id from messages, breaking tool-use conversations.
NADIRCLAW_OPTIMIZE=off

# LiteLLM: merge consecutive user/tool blocks for Bedrock compatibility
LITELLM_MODIFY_PARAMS=true

# Server (localhost only)
NADIRCLAW_PORT=4000

# Logging
NADIRCLAW_LOG_DIR=~/.nadirclaw/logs
NADIRCLAW_LOG_RAW=false
