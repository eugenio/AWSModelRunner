# NadirClaw configuration for AWS Bedrock Mantle + OpenRouter
# Uses Bedrock Mantle (OpenAI-compatible) for most models,
# OpenRouter for Qwen 3.6 Plus (1M context, free preview)
# Copy to ~/.nadirclaw/.env or set as environment variables

# Default Bedrock Mantle endpoint (eu-west-2 London)
NADIRCLAW_API_BASE=https://bedrock-mantle.eu-west-2.api.aws/v1
# API key loaded from ~/.nadirclaw/mantle.env at container startup
# OPENAI_API_KEY is set via docker-compose env_file

# OpenRouter API key (for Qwen 3.6 Plus routing)
# Get a free key at https://openrouter.ai/keys
# Loaded from ~/.nadirclaw/openrouter.env via docker-compose env_file

# Per-model endpoint overrides (multi-provider routing)
# Qwen 3.6 Plus routed to OpenRouter; everything else uses the default Bedrock eu-west-2
NADIRCLAW_MODEL_API_BASES=openrouter/qwen/qwen3.6-plus-preview=https://openrouter.ai/api/v1

# Three-tier routing (Bedrock + OpenRouter)
#   Budget:  Qwen3 Coder 30B  -  32K ctx, $0.15/$0.60/M, Bedrock eu-west-2
#   Mid:     Qwen3 Coder 480B - 256K ctx, $0.45/$1.80/M, Bedrock eu-west-2
#   Premium: Qwen 3.6 Plus    -   1M ctx, free (preview), OpenRouter
NADIRCLAW_SIMPLE_MODEL=openai/qwen.qwen3-coder-30b-a3b-v1:0
NADIRCLAW_MID_MODEL=openai/qwen.qwen3-coder-480b-a35b-v1:0
NADIRCLAW_COMPLEX_MODEL=openrouter/qwen/qwen3.6-plus-preview

# Context-based routing override
# Requests with >256K context bypass tier classification and route to Qwen 3.6 Plus
NADIRCLAW_CONTEXT_OVERFLOW_MODEL=openrouter/qwen/qwen3.6-plus-preview
NADIRCLAW_CONTEXT_OVERFLOW_THRESHOLD=256000

# Tier thresholds (score 0-1: <= simple_max -> budget, >= complex_min -> premium)
NADIRCLAW_TIER_THRESHOLDS=0.35,0.65

# Fallback chains (try next model on failure)
# Ordered by: capability → cost (best first, cheapest last)
NADIRCLAW_FALLBACK_CHAIN=openrouter/qwen/qwen3.6-plus-preview,openai/qwen.qwen3-coder-480b-a35b-v1:0,openai/moonshotai.kimi-k2.5,openai/qwen.qwen3-coder-30b-a3b-v1:0
NADIRCLAW_SIMPLE_FALLBACK=openai/qwen.qwen3-coder-480b-a35b-v1:0,openai/minimax.minimax-m2.1,openai/zai.glm-4.7
NADIRCLAW_MID_FALLBACK=openrouter/qwen/qwen3.6-plus-preview,openai/moonshotai.kimi-k2.5,openai/zai.glm-4.7
NADIRCLAW_COMPLEX_FALLBACK=openai/qwen.qwen3-coder-480b-a35b-v1:0,openai/moonshotai.kimi-k2.5,openai/zai.glm-4.7

# Budget controls (USD)
NADIRCLAW_DAILY_BUDGET=5.00
NADIRCLAW_MONTHLY_BUDGET=80.00
NADIRCLAW_BUDGET_WARN_THRESHOLD=0.8
NADIRCLAW_BUDGET_STDOUT_ALERTS=true
NADIRCLAW_BUDGET_ENFORCE=true

# Context optimization DISABLED — the optimizer strips tool_calls and
# tool_call_id from messages, breaking tool-use conversations.
# See: optimize_messages() converts messages to {"role","content"} only.
NADIRCLAW_OPTIMIZE=off

# LiteLLM: merge consecutive user/tool blocks for Bedrock compatibility
LITELLM_MODIFY_PARAMS=true

# Server (localhost only)
NADIRCLAW_PORT=4000

# Logging
NADIRCLAW_LOG_DIR=~/.nadirclaw/logs
NADIRCLAW_LOG_RAW=false
