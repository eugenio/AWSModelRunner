# .coveragerc — coverage config for aws-model-runner

[run]
source =
    src
    scripts

omit =
    */tests/*
    */__pycache__/*
    */migrations/*
    */_vendor/*

branch = true

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:

show_missing = true
precision = 1
# Gate set to 0 until test suite is built out (src/ has minimal code).
# Raise to 97 once production code + tests are in place.
fail_under = 0

[html]
directory = coverage_html

[xml]
output = coverage.xml
